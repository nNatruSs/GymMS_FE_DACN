# Application
APP_NAME=gms-backend
APP_PORT=3500
APP_HOST=localhost

# Frontend
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
 
# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-database-password-here
DATABASE_NAME=gms
DATABASE_SCHEMA=public
DATABASE_URL="postgresql://postgres:your-password@localhost:5432/gms?schema=public"

# JWT
JWT_SECRET_ACCESS_TOKEN=your-super-secret-access-token-key-change-this
JWT_SECRET_REFRESH_TOKEN=your-super-secret-refresh-token-key-change-this
ACCESS_TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=7d
 
# Password Hashing
HASH_SALT_LENGTH=10
 
# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password-16-chars
EMAIL_FROM="GMS <your-email@gmail.com>"

# Environment
NODE_ENV=development
